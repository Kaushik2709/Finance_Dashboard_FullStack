# Frontend API base URL used by src/api/fetch.js
# - Recommended: keep as /api and rely on Vite proxy in development.
# - If you deploy the frontend separately, set this to your backend URL + /api.
VITE_API_URL=/api

# Vite dev server proxy target (where /api requests go in development)
# Point this at your running backend (Finance_api).
VITE_API_PROXY_TARGET=http://localhost:3000
